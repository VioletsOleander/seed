  "ty.disableLanguageServices": false,
  "ty.completions.autoImport": false,
  "evenBetterToml.formatter.allowedBlankLines": 1,
  "evenBetterToml.formatter.columnWidth": 120,
  "evenBetterToml.formatter.trailingNewline": true,
  "json.schemaDownload.trustedDomains": {
    "https://aka.ms/terminal-profiles-schema": true,
    "https://esm.sh/gh/catppuccin/vscode@catppuccin-vsc-v3.18.1/packages/catppuccin-vsc/schemas": true,
    "https://raw.githubusercontent.com/DavidAnson/markdownlint/v0.40.0/schema": true,
    "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/": true,
