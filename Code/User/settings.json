{
  "vscode-neovim.neovimExecutablePaths.win32": "C:\\Users\\Vios\\scoop\\apps\\neovim\\0.11.6\\bin\\nvim.exe",
  "vscode-neovim.compositeKeys": {
    "jj": {
      "command": "vscode-neovim.escape",
      "args": [],
    },
    "jk": {
      "command": "vscode-neovim.lua",
      "args": [
        [
          "local code = require('vscode')",
          "code.action('vscode-neovim.escape')",
          "code.action('workbench.action.files.save')",
        ],
      ],
    },
  },
  "vscode-neovim.compositeTimeout": 300,
  "vscode-neovim.highlightGroups.highlights": {
    "Cursor": {
      "backgroundColor": "#526fffcc",
      "foregroundColor": "#ffffff",
    },
  },
  "vscode-neovim.ctrlKeysForNormalMode": [
    "a",
    "b",
    "d",
    "e",
    "f",
    "g",
    "h",
    "i",
    "j",
    "k",
    "l",
    "m",
    "o",
    "r",
    "t",
    "u",
    "v",
    "w",
    "x",
    "y",
    "z",
    "/",
    "]",
  ],
  "workbench.editor.restoreEditors": true,
  "workbench.editor.showTabs": "single",
  "workbench.editor.useModal": "off",
  "workbench.iconTheme": null,
  "workbench.colorCustomizations": {
    "[Atom One Light]": {
      "editorCursor.foreground": "#526fffcc",
      "editorCursor.background": "#ffffff",
      "terminalCursor.foreground": "#526fffcc",
      "terminalCursor.background": "#ffffff",
    },
    "[Tokyo Night Light]": {
      // "editor.foreground":"#343b59",
      // "editor.background": "#e6e7ed",
      // let the editor ground header looks like is merged with the editor background,
      "editorGroupHeader.noTabsBackground": "#e6e7ed",
      "editorGroupHeader.border": "#e6e7ed",
    },
  },
  "workbench.activityBar.location": "hidden",
  "window.menuBarVisibility": "hidden",
  "search.quickOpen.history.filterSortOrder": "recency",
  "zenMode.showTabs": "none",
  "explorer.confirmDelete": false,
  "explorer.compactFolders": false,
  "editor.cursorBlinking": "solid",
  "editor.cursorStyle": "line",
  "editor.lineNumbers": "off",
  "editor.inlayHints.enabled": "off",
  "editor.fontSize": 15,
  "editor.fontFamily": "Fira Code Retina, Consolas, monospace",
  "editor.rulers": [
    110
  ],
  "editor.minimap.renderCharacters": false,
  "editor.lightbulb.enabled": "off",
  "editor.renderLineHighlight": "none",
  "editor.formatOnSave": true,
  "editor.formatOnPaste": true,
  "editor.insertSpaces": true,
  "editor.tabSize": 4,
  "editor.detectIndentation": true,
  "[markdown]": {
    "editor.wordWrap": "wordWrapColumn",
    "editor.wordWrapColumn": 110,
    "editor.rulers": [
      110
    ],
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.wordBasedSuggestions": "currentDocument",
    "editor.quickSuggestions": {
      "other": "off",
      "strings": "off",
      "comments": "off",
    },
  },
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.codeActionsOnSave": {
      "source.organizeImports": "always",
    },
  },
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features",
  },
  "[toml]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "tamasfe.even-better-toml",
  },
  "[jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features",
    "editor.quickSuggestions": {
      "strings": true,
    },
    "editor.suggest.insertMode": "replace",
  },
  "[yaml]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.insertSpaces": true,
    "editor.tabSize": 4,
    "editor.autoIndent": "full",
    "editor.quickSuggestions": {
      "other": "on",
      "comments": "on",
      "strings": "on",
    },
  },
  "[lua]": {
    "editor.defaultFormatter": "JohnnyMorganz.stylua",
  },
  "[rust]": {
    "editor.defaultFormatter": "rust-lang.rust-analyzer"
  },
  "files.autoSave": "afterDelay",
  "files.readonlyInclude": {
    ".venv/**": true,
    ".pixi/**": true,
  },
  "files.insertFinalNewline": true,
  "files.associations": {
    ".bash.template": "shellscript",
    "config.nu.template": "nushell",
  },
  "terminal.integrated.fontFamily": "Fira Code Retina, Fira Code Nerd Font Mono",
  "terminal.integrated.fontSize": 14,
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.copyOnSelection": true,
