  "markdown.preview.doubleClickToSwitchToEditor": false,
  "markdown.preview.fontFamily": "Inter, SimHei, Microsoft YaHei, sans-serif",
  "markdown.preview.fontSize": 16,
  "markdown.preview.breaks": true,
  "python.languageServer": "None",
